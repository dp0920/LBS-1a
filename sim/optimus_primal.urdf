<?xml version="1.0"?>
<robot name="optimus_primal">

  <!--
    Optimus Primal Quadruped URDF
    ================================
    Body frame dimensions (approximate from measurements):
      Rear hip spacing (L-R):  160.255 mm = 0.160255 m
      Front hip spacing (L-R): 131.673 mm = 0.131673 m
      Front-to-rear hip spacing: 181.5 mm = 0.1815 m

    Leg geometry:
      Femur (upper_link): 78 mm = 0.078 m
      Tibia (lower_link): 104 mm = 0.104 m

    Standing pose angles (from servo diff values):
      Hip:  ~35 deg from vertical
      Knee: ~80 deg from hip

    Leg naming convention (from robot's forward-facing perspective):
      FL = front-left, FR = front-right
      RL = rear-left,  RR = rear-right

    TPU sock friction values (TPU on hard floor):
      Sliding friction: 1.0  (typical range 0.8-1.2)
      Torsional:        0.01
      Rolling:          0.002
      condim=4 enables full friction cone
  -->

  <mujoco>
    <compiler balanceinertia="true" discardvisual="true"/>
    <default>
      <!-- Default for all structural geoms (PETG-CF frame, ABS links) -->
      <joint damping="0.05" armature="0.01"/>
      <geom friction="0.6 0.01 0.001" condim="3" contype="1" conaffinity="1"/>
    </default>
    <default class="foot">
      <!-- TPU sock contact: grippy, soft contact, full friction cone -->
      <geom friction="1.0 0.01 0.002"
            condim="4"
            contype="1"
            conaffinity="1"
            solimp="0.9 0.95 0.001"
            solref="0.02 1"/>
    </default>
  </mujoco>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <inertial>
      <mass value="0.672"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00672" iyy="0.00896" izz="0.01120"
               ixy="0.0"     ixz="0.0"     iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.18 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== FRONT-LEFT LEG ==================== -->

  <link name="upper_link_fl">
    <inertial>
      <mass value="0.085"/>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <inertia ixx="0.000050" iyy="0.000085" izz="0.000050"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/upper_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.078"/>
      </geometry>
    </collision>
  </link>

  <link name="lower_link_fl">
    <inertial>
      <mass value="0.065"/>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <inertia ixx="0.000065" iyy="0.000122" izz="0.000065"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/lower_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.104"/>
      </geometry>
    </collision>
  </link>

  <!-- FL foot — TPU sock sphere -->
  <link name="foot_fl">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="tpu_blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
  </link>

  <joint name="hip_fl" type="revolute">
    <parent link="base_link"/>
    <child link="upper_link_fl"/>
    <origin xyz="0.0908 0.0658 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="knee_fl" type="revolute">
    <parent link="upper_link_fl"/>
    <child link="lower_link_fl"/>
    <origin xyz="0 0 -0.078" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="foot_joint_fl" type="fixed">
    <parent link="lower_link_fl"/>
    <child link="foot_fl"/>
    <origin xyz="0 0 -0.104" rpy="0 0 0"/>
  </joint>

  <!-- ==================== FRONT-RIGHT LEG ==================== -->

  <link name="upper_link_fr">
    <inertial>
      <mass value="0.085"/>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <inertia ixx="0.000050" iyy="0.000085" izz="0.000050"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/upper_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.078"/>
      </geometry>
    </collision>
  </link>

  <link name="lower_link_fr">
    <inertial>
      <mass value="0.065"/>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <inertia ixx="0.000065" iyy="0.000122" izz="0.000065"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/lower_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.104"/>
      </geometry>
    </collision>
  </link>

  <link name="foot_fr">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="tpu_blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
  </link>

  <joint name="hip_fr" type="revolute">
    <parent link="base_link"/>
    <child link="upper_link_fr"/>
    <origin xyz="0.0908 -0.0658 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="knee_fr" type="revolute">
    <parent link="upper_link_fr"/>
    <child link="lower_link_fr"/>
    <origin xyz="0 0 -0.078" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="foot_joint_fr" type="fixed">
    <parent link="lower_link_fr"/>
    <child link="foot_fr"/>
    <origin xyz="0 0 -0.104" rpy="0 0 0"/>
  </joint>

  <!-- ==================== REAR-LEFT LEG ==================== -->

  <link name="upper_link_rl">
    <inertial>
      <mass value="0.085"/>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <inertia ixx="0.000050" iyy="0.000085" izz="0.000050"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/upper_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.078"/>
      </geometry>
    </collision>
  </link>

  <link name="lower_link_rl">
    <inertial>
      <mass value="0.065"/>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <inertia ixx="0.000065" iyy="0.000122" izz="0.000065"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/lower_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.104"/>
      </geometry>
    </collision>
  </link>

  <link name="foot_rl">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="tpu_blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
  </link>

  <joint name="hip_rl" type="revolute">
    <parent link="base_link"/>
    <child link="upper_link_rl"/>
    <origin xyz="-0.0908 0.0801 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="knee_rl" type="revolute">
    <parent link="upper_link_rl"/>
    <child link="lower_link_rl"/>
    <origin xyz="0 0 -0.078" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="foot_joint_rl" type="fixed">
    <parent link="lower_link_rl"/>
    <child link="foot_rl"/>
    <origin xyz="0 0 -0.104" rpy="0 0 0"/>
  </joint>

  <!-- ==================== REAR-RIGHT LEG ==================== -->

  <link name="upper_link_rr">
    <inertial>
      <mass value="0.085"/>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <inertia ixx="0.000050" iyy="0.000085" izz="0.000050"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/upper_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.039" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.078"/>
      </geometry>
    </collision>
  </link>

  <link name="lower_link_rr">
    <inertial>
      <mass value="0.065"/>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <inertia ixx="0.000065" iyy="0.000122" izz="0.000065"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/lower_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.052" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.104"/>
      </geometry>
    </collision>
  </link>

  <link name="foot_rr">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0.0"      ixz="0.0"      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="tpu_blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
  </link>

  <joint name="hip_rr" type="revolute">
    <parent link="base_link"/>
    <child link="upper_link_rr"/>
    <origin xyz="-0.0908 -0.0801 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="knee_rr" type="revolute">
    <parent link="upper_link_rr"/>
    <child link="lower_link_rr"/>
    <origin xyz="0 0 -0.078" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="2.5" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="foot_joint_rr" type="fixed">
    <parent link="lower_link_rr"/>
    <child link="foot_rr"/>
    <origin xyz="0 0 -0.104" rpy="0 0 0"/>
  </joint>

</robot>
